# ─── Authentication (Clerk) ─────────────────────────────
# Get these from https://dashboard.clerk.com
# Leave blank to use dev-mode simulated auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

