# ─── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── AI / LLM ───────────────────────────────────────────
OPENAI_API_KEY="sk-proj-your-openai-key-here"

# ─── Scraping APIs ──────────────────────────────────────
SERP_API_KEY="your-serpapi-key-here"
