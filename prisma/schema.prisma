// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}


model User {
  id            String            @id @default(uuid())
  clerkId       String            @unique // We'll populate this later with Clerk
  email         String
  name          String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  workspaces    Workspace[]
  memberships   WorkspaceMember[]
  comments      Comment[]
  assignedLeads Lead[]            @relation("LeadAssignee")
  activityLogs  ActivityLog[]
}

model Workspace {
  id            String            @id @default(uuid())
  name          String
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  leads              Lead[]
  folders            Folder[]
  tags               Tag[]
  members            WorkspaceMember[]
  activityLogs       ActivityLog[]
  agencyProfile      AgencyProfile?
  proposals          Proposal[]
  monitorAlerts      MonitorAlert[]
  discoveryCache     SmartDiscoveryCache[]

  @@index([userId])
}

model Lead {
  id                 String   @id @default(uuid())
  workspaceId        String
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // Identity
  name               String
  domain             String?
  description        String?
  avatar             String?
  
  // Source tracking
  source             String   @default("unknown")
  sourceUrl          String   @default("")
  profileUrl         String?
  socialProfiles     Json?    // { linkedin, instagram, twitter, ... }
  sources            String[] // e.g. ["linkedin", "website"]
  
  // Contact info
  emails             String[]
  phones             String[]
  contactSources     Json?    // Where each email/phone was found
  
  // Business details
  location           String?
  address            Json?    // Structured address
  industry           String?
  employeeCount      String?
  foundedYear        Int?
  revenue            String?
  
  // Owner
  ownerName          String?
  ownerTitle         String?
  ownerEmail         String?
  ownerPhone         String?
  ownerLinkedIn      String?
  
  // Social metrics
  followers          Int?
  following          Int?
  engagement         Float?
  postCount          Int?
  lastPostDate       DateTime?
  
  // Review & reputation
  rating             Float?
  reviewCount        Int?
  
  // Technical
  techStack          String[]
  hasWebsite         Boolean  @default(false)
  websiteStatus      String?
  
  // Scraper raw JSON data (Legacy/Raw)
  linkedin           Json?
  instagram          Json?
  google             Json?
  website            Json?
  
  // Opportunity
  opportunitySignals String[] // Generated by our signals.ts engine
  buyingSignals      String[] // e.g. ["hiring", "funding"]
  postmortem         Json?
  audit              Json?
  opportunityScore   Int?
  matchScore         Int?
  
  // Ads
  isRunningAds       Boolean  @default(false)
  adPlatforms        String[]
  adCount            Int?
  
  // Dashboard state
  status             String   @default("new") // new, active, warm, cold, closed
  notes              String?
  folderId           String?
  folder             Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags               Tag[]
  
  // Phase 4: Team & Assignment
  assignedToId       String?
  assignedTo         User?    @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  comments           Comment[]
  proposal           Proposal?
  monitorAlerts      MonitorAlert[]

  // Meta
  dataCompleteness   Int      @default(0)
  scrapedAt          DateTime @default(now())
  enrichedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([workspaceId])
  @@index([folderId])
  @@index([assignedToId])
  @@index([domain])
  @@index([source])
}

model Folder {
  id          String   @id @default(uuid())
  name        String
  color       String?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  leads       Lead[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

model Tag {
  id          String   @id @default(uuid())
  name        String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  leads       Lead[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String    // "OWNER" | "MEMBER"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

model Comment {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leadId])
  @@index([userId])
}

model ActivityLog {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String    // e.g. "lead_created", "lead_status_updated", "proposal_created", "member_invited", "comment_added", "lead_assigned"
  description String
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
  @@index([userId])
}

model AgencyProfile {
  id            String   @id @default(uuid())
  workspaceId   String   @unique
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  slug          String   @unique
  name          String
  tagline       String?
  description   String?
  services      Json     // Array of services: { name: string, description: string, price: string, priority: number }
  portfolio     Json?    // Array of portfolio items: { title: string, description: string, link?: string, image?: string }
  caseStudies   Json?    // Array of case studies: { client: string, title: string, challenge: string, solution: string, results: string }
  industries    String[] // e.g. ["saas", "e-commerce", "local-business"]
  techStack     String[] // e.g. ["nextjs", "react", "shopify", "wordpress"]
  pricingModel  String?  // e.g. "retainer", "project-based", "hourly"
  contactInfo   Json?    // { email?: string, website?: string, phone?: string }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Proposal {
  id            String   @id @default(uuid())
  leadId        String   @unique
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  timeline      Json?    // Array of milestones: { phase: string, duration: string, deliverables: string[] }
  deliverables  Json?    // Array of items: { title: string, cost: number, description?: string }
  budget        Float?
  status        String   @default("draft") // draft, sent, approved, rejected
  notes         String?
  requirements  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([workspaceId])
}

// Phase 5: Client Health Monitor
model MonitorAlert {
  id              String    @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  leadId          String?
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  domain          String
  status          String    // healthy | warning | critical | unknown
  uptime          Boolean?
  httpStatus      Int?
  responseTimeMs  Int?
  sslValid        Boolean?
  alerts          Json      // Array of { type, severity, message }
  checkedAt       DateTime  @default(now())

  @@index([workspaceId])
  @@index([leadId])
}

// Phase 5: Smart Lead Discovery Cache
model SmartDiscoveryCache {
  id              String    @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recommendations Json      // SmartDiscoveryData
  summary         String
  generatedAt     DateTime  @default(now())

  @@index([workspaceId])
}
