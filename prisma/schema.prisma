// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique // We'll populate this later with Clerk
  email     String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces Workspace[]
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads     Lead[]
  folders   Folder[]
  tags      Tag[]

  @@index([userId])
}

model Lead {
  id          String   @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  // Basic info
  name        String
  domain      String?
  description String?
  location    String?
  industry    String?
  
  // Scraper raw JSON data (store as JSONB to allow flexible enrichment)
  linkedin    Json?
  instagram   Json?
  google      Json?
  website     Json?
  
  // Generated arrays
  sources             String[] // e.g. ["linkedin", "website"]
  opportunitySignals  String[] // Generated by our signals.ts engine
  buyingSignals       String[] // e.g. ["hiring", "funding"]
  
  // Phase 2: AI Research Data
  postmortem          Json?
  audit               Json?
  opportunityScore    Int?
  
  // Dashboard state
  status      String   @default("new") // new, active, warm, cold, closed
  notes       String?
  folderId    String?
  folder      Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
  tags        Tag[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
  @@index([folderId])
}

model Folder {
  id          String   @id @default(uuid())
  name        String
  color       String?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  leads       Lead[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}

model Tag {
  id          String   @id @default(uuid())
  name        String
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  leads       Lead[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([workspaceId])
}
